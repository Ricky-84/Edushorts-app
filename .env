# App Configuration
NODE_ENV=development
PORT=3000
APP_NAME=EduShorts
APP_VERSION=0.1.0

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/edushorts_dev
DATABASE_URL_PROD=postgresql://username:password@localhost:5432/edushorts_prod

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=93dd4247ac406064fe723f0c6287f7cba0d2c43b2f454ffd3cc298379a54832f9ceb1a1ef508b37cfef000f3f128168c8d8c1bc5718eddc030d6a4a471ea86c9
JWT_EXPIRES_IN=7d

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=edushorts-videos
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Synthesia API (for AI video generation)
SYNTHESIA_API_KEY=your-synthesia-api-key

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@edushorts.com

# Push Notifications
FIREBASE_SERVER_KEY=your-firebase-server-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=mp4,mov,avi

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8081